{
  "id": "clawforce",
  "name": "Clawforce",
  "description": "Accountability layer for autonomous AI agents — budget enforcement, compliance tracking, org hierarchy, performance management, and trust evolution",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "projectsDir": {
        "type": "string"
      },
      "configDir": {
        "type": "string"
      },
      "managedRoots": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "managedAgentIds": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "discoverWorkspaceRoots": {
        "type": "boolean"
      },
      "sweepIntervalMs": {
        "type": "number"
      },
      "defaultMaxRetries": {
        "type": "number"
      },
      "staleTaskHours": {
        "type": "number"
      },
      "cronStuckTimeoutMs": {
        "type": "number"
      },
      "cronMaxConsecutiveFailures": {
        "type": "number"
      },
      "syncAgents": {
        "type": "boolean"
      },
      "standaloneDashboard": {
        "type": "boolean"
      },
      "ghostRecall": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "intensity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "windowSize": {
            "type": "number"
          },
          "maxInjectedChars": {
            "type": "number"
          },
          "maxSearches": {
            "type": "number"
          },
          "debug": {
            "type": "boolean"
          },
          "injectExpectations": {
            "type": "boolean"
          }
        }
      },
      "memoryFlush": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "flushInterval": {
            "type": "number"
          },
          "minToolCalls": {
            "type": "number"
          }
        }
      }
    }
  }
}
