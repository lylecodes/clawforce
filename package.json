{
  "name": "clawforce",
  "version": "0.2.0",
  "description": "Team coordination SDK for autonomous AI agents — budget, trust, tasks, approvals, dispatch, and 15 validation layers",
  "type": "module",
  "license": "MIT",
  "author": "Lyle Jensen",
  "repository": {
    "type": "git",
    "url": "https://github.com/lylecodes/clawforce.git"
  },
  "homepage": "https://github.com/lylecodes/clawforce",
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "coordination",
    "autonomous",
    "budget",
    "trust",
    "approvals",
    "tasks",
    "dispatch",
    "validation",
    "sdk",
    "codex",
    "openai",
    "openclaw"
  ],
  "engines": {
    "node": ">=22.22.0"
  },
  "main": "./dist/src/sdk/index.js",
  "types": "./dist/src/sdk/index.d.ts",
  "bin": {
    "cf": "./bin/cf"
  },
  "exports": {
    ".": {
      "types": "./dist/src/sdk/index.d.ts",
      "default": "./dist/src/sdk/index.js"
    },
    "./sdk": {
      "types": "./dist/src/sdk/index.d.ts",
      "default": "./dist/src/sdk/index.js"
    },
    "./advanced": {
      "types": "./dist/src/advanced.d.ts",
      "default": "./dist/src/advanced.js"
    },
    "./internal": {
      "types": "./dist/src/internal.d.ts",
      "default": "./dist/src/internal.js"
    },
    "./dashboard": {
      "types": "./dist/src/dashboard/plugin.d.ts",
      "default": "./dist/src/dashboard/plugin.js"
    },
    "./dashboard/extensions": {
      "types": "./dist/src/dashboard/extensions.d.ts",
      "default": "./dist/src/dashboard/extensions.js"
    },
    "./openclaw": {
      "types": "./dist/adapters/openclaw.d.ts",
      "default": "./dist/adapters/openclaw.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "adapters",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./adapters/openclaw.ts"
    ]
  },
  "scripts": {
    "build": "./scripts/with-runtime-node.sh ./node_modules/typescript/bin/tsc",
    "prepublishOnly": "npm run build && npm run test",
    "test": "./scripts/vitest-runtime.sh",
    "test:watch": "./scripts/vitest-runtime.sh watch",
    "typecheck": "./scripts/with-runtime-node.sh ./node_modules/typescript/bin/tsc --noEmit",
    "check": "./scripts/with-runtime-node.sh ./node_modules/typescript/bin/tsc --noEmit",
    "runtime:doctor": "./scripts/runtime-doctor.sh",
    "cf": "./bin/cf"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "better-sqlite3": "^12.8.0",
    "filtrex": "3.1.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1",
    "openclaw": "^2026.3.13",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
