{
  "name": "clawforce",
  "version": "0.2.0",
  "description": "Team coordination SDK for autonomous AI agents — budget, trust, tasks, approvals, dispatch, and 15 validation layers",
  "type": "module",
  "license": "MIT",
  "author": "Lyle Jensen",
  "repository": {
    "type": "git",
    "url": "https://github.com/lylecodes/clawforce.git"
  },
  "homepage": "https://github.com/lylecodes/clawforce",
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "coordination",
    "autonomous",
    "budget",
    "trust",
    "approvals",
    "tasks",
    "dispatch",
    "validation",
    "sdk",
    "openclaw"
  ],
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/src/sdk/index.js",
  "types": "./dist/src/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/sdk/index.d.ts",
      "default": "./dist/src/sdk/index.js"
    },
    "./sdk": {
      "types": "./dist/src/sdk/index.d.ts",
      "default": "./dist/src/sdk/index.js"
    },
    "./internal": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./dashboard": {
      "types": "./dist/src/dashboard/plugin.d.ts",
      "default": "./dist/src/dashboard/plugin.js"
    },
    "./openclaw": {
      "types": "./dist/adapters/openclaw.d.ts",
      "default": "./dist/adapters/openclaw.js"
    }
  },
  "files": [
    "dist",
    "adapters",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./adapters/openclaw.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit",
    "cf": "npx tsx src/cli.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "filtrex": "3.1.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1",
    "openclaw": "^2026.3.13",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
